{{!
    @template theme_nhsetel/nav

    This template renders the top nav.
}}

<nav class="nhsuk-header__navigation" role="navigation" aria-label="Primary navigation">
    <div class="nhsuk-header__navigation-container nhsuk-width-container">
        <ul class="nhsuk-header__navigation-list"
            id="moremenu{{#moremenuid}}-{{moremenuid}}{{/moremenuid}}-{{#navbarstyle}}{{navbarstyle}}{{/navbarstyle}}{{^navbarstyle}}default{{/navbarstyle}}"
            role="{{#istablist}}tablist{{/istablist}}{{^istablist}}menubar{{/istablist}}">
            {{#primarymoremenu}}
                <li class="nhsuk-header__navigation-item nav-item dropdown dropdownmoremenu d-none {{#isactive}}nhsuk-header__navigation-item__item--current{{/isactive}}" role="none" data-region="morebutton">
                    <a class="nhsuk-header__navigation-link dropdown-toggle" href="#" id="moremenu-dropdown{{#moremenuid}}-{{moremenuid}}{{/moremenuid}}" role="{{#istablist}}tab{{/istablist}}{{^istablist}}menuitem{{/istablist}}" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" tabindex="-1">
                        {{#str}}moremenu, core{{/str}}
                    </a>
                </li>
            {{/primarymoremenu}}


            {{!-- BEGIN: Custom Navigation items --}}
            {{#customnavigation}}
                <li class="nhsuk-header__navigation-item nav-item" role="none"> {{!-- Added nhsuk-header__navigation-item and nav-item classes --}}
                    <a class="nhsuk-header__navigation-link" href="{{url}}" role="menuitem" {{#openInNewTab}}target="_blank"{{/openInNewTab}}> {{!-- Added nhsuk-header__navigation-link and nav-link classes --}}
                        {{title}}
                        {{#hasnotification}}
                            <span class="nhsuk-tag nhsuk-tag--notification">{{notificationcount}}</span> {{!-- Used NHS.UK tag for consistency --}}
                        {{/hasnotification}}
                    </a>
                </li>
            {{/customnavigation}}       
            {{!-- END: Custom Navigation items --}}

            <li class="nhsuk-header__menu" hidden>
                <button class="nhsuk-header__menu-toggle nhsuk-header__navigation-link" id="toggle-menu" aria-expanded="false">
                    <span class="nhsuk-u-visually-hidden">Browse</span>
                    {{#str}}moremenu, core{{/str}}                    
                </button>
            </li>
        </ul>   
    </div>
</nav>

